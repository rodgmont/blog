# Copia este archivo a .env.vercel.push (está en .gitignore) y rellena los valores.
#
# Token Vercel: https://vercel.com/account/tokens
# Project ID: Vercel → tu proyecto → Settings → General → Project ID
# Team ID (solo si el proyecto está en un team): Team Settings → Team ID
#
# Upstash: consola → tu base Redis → REST API → URL y TOKEN
# Sitio: dominio canónico (el mismo que uses en el navegador)

VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=

NEXT_PUBLIC_SITE_URL=https://franrodgmont.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
